async function getCity(stateSlug: string, citySlug: string) {
  try {
    // Em produção, usar dados estáticos
    if (process.env.NODE_ENV === 'production') {
      const staticCity = staticCitiesData[citySlug as keyof typeof staticCitiesData];
      if (staticCity && staticCity.state.slug === stateSlug) {
        return staticCity;
      }
      return null;
    }

    // Em desenvolvimento, tentar usar o banco de dados
    const { db } = await import('@/lib/db');
    const city = await db.city.findFirst({
      where: {
        slug: citySlug,
        state: {
          slug: stateSlug
        }
      },
      include: {
        state: {
          include: {
            dddCodes: true
          }
        },
        dddCodes: true
      }
    });

    return city;
  } catch (error) {
    console.error('Error fetching city:', error);
    // Fallback para dados estáticos
    const staticCity = staticCitiesData[citySlug as keyof typeof staticCitiesData];
    if (staticCity && staticCity.state.slug === stateSlug) {
      return staticCity;
    }
    return null;
  }
}

async function getNearbyCities(stateId: string, currentCityId: string, limit: number = 5) {
  try {
    // Em produção, retornar cidades estáticas próximas
    if (process.env.NODE_ENV === 'production') {
      const nearbyCities = Object.values(staticCitiesData)
        .filter(city => city.state.id !== stateId || city.id !== currentCityId)
        .slice(0, limit);
      return nearbyCities;
    }

    // Em desenvolvimento, usar banco de dados
    const { db } = await import('@/lib/db');
    const nearbyCities = await db.city.findMany({
      where: {
        stateId: stateId,
        id: {
          not: currentCityId
        }
      },
      orderBy: [
        { population: 'desc' }
      ],
      take: limit,
      include: {
        state: true,
        dddCodes: true
      }
    });

    return nearbyCities;
  } catch (error) {
    console.error('Error fetching nearby cities:', error);
    // Fallback para cidades estáticas
    const nearbyCities = Object.values(staticCitiesData)
      .filter(city => city.state.id !== stateId || city.id !== currentCityId)
      .slice(0, limit);
    return nearbyCities;
  }
}

export async function generateMetadata({ params }: CityPageProps): Promise<Metadata> {
  try {
    const { slug, citySlug } = await params;
    const city = await getCity(slug, citySlug);
    
    if (!city) {
      return {
        title: 'Cidade não encontrada',
        description: 'A cidade solicitada não foi encontrada em nossa base de dados.'
      };
    }

    const dddCodes = city.dddCodes.map(ddd => ddd.code).join(', ');
    
    return {
      title: `DDD de ${city.name} - Código Telefônico (${dddCodes})`,
      description: `Buscando pelo DDD de ${city.name}? Descubra o código DDD de ${city.name}, ${city.state.name}: ${dddCodes}. Informações completas para fazer ligações telefônicas.`,
      keywords: `DDD de ${city.name}, DDD ${city.name}, código DDD ${city.name}, ${city.name} ${city.state.name}, telefonia ${city.name}, ${city.dddCodes.map(d => `DDD ${d.code}`).join(', ')}`,
      openGraph: {
        title: `DDD de ${city.name} - Código Telefônico Completo`,
        description: `Código DDD de ${city.name}, ${city.state.name}: ${dddCodes}. Saiba como ligar para ${city.name} do Brasil e do exterior.`,
        type: 'website',
        locale: 'pt_BR'
      },
      twitter: {
        card: 'summary_large_image',
        title: `DDD de ${city.name} - Código Telefônico`,
        description: `Descubra o código DDD de ${city.name} e saiba como fazer ligações telefônicas.`
      },
      alternates: {
        canonical: `https://meuddd.com/estado/${city.state.slug}/cidade/${city.slug}`
      },
      other: {
        'geo.region': city.state.code,
        'geo.placename': city.name
      }
    };
  } catch (error) {
    console.error('Error generating city metadata:', error);
    return {
      title: 'Erro ao carregar página',
      description: 'Ocorreu um erro ao carregar as informações da cidade.'
    };
  }
}

export default async function CityPage({ params }: CityPageProps) {
  try {
    const { slug, citySlug } = await params;
    const city = await getCity(slug, citySlug);

    if (!city) {
      notFound();
    }

    const nearbyCities = await getNearbyCities(city.state.id, city.id);

    const formatNumber = (num?: number | null) => {
      if (!num) return '';
      return num.toLocaleString('pt-BR');
    };

    const formatArea = (area?: number | null) => {
      if (!area) return '';
      return `${area.toLocaleString('pt-BR')} km²`;
    };

    const baseUrl = process.env.NEXT_PUBLIC_BASE_URL || 'https://meuddd.com';
    const canonicalUrl = `${baseUrl}/estado/${city.state.slug}/cidade/${city.slug}`;

    const breadcrumbItems = [
      { name: 'Home', url: baseUrl },
      { name: city.state.name, url: `${baseUrl}/estado/${city.state.slug}` },
      { name: city.name, url: canonicalUrl }
    ];

    // Generate tourist attractions based on city characteristics - FIXED
    const generateTouristAttractions = (cityName: string, stateName: string) => {
      const attractions = [
        {
          name: `Centro Histórico de ${cityName}`,
          description: 'Conheça a história e cultura local no coração da cidade',
          location: 'Centro da cidade',
          externalUrl: `https://pt.wikipedia.org/wiki/${cityName.replace(/ /g, '_')}`
        },
        {
          name: `Praça Central de ${cityName}`,
          description: 'Ponto de encontro tradicional e espaço para eventos culturais',
          location: 'Área central',
          externalUrl: `https://www.turismo.br/${stateName.toLowerCase()}/${cityName.toLowerCase()}`
        },
        {
          name: `Museu Municipal de ${cityName}`,
          description: 'Acervos que contam a história da cidade e da região',
          location: 'Centro cultural',
          externalUrl: `https://www.cultura.${stateName.toLowerCase()}.gov.br/museus`
        },
        {
          name: `Parque Natural de ${cityName}`,
          description: 'Área de preservação ambiental com trilhas e beleza natural',
          location: 'Zona rural',
          externalUrl: `https://www.icmbio.gov.br/parcas`
        }
      ];
      return attractions;
    };

    // Generate public utilities
    const generatePublicUtilities = (cityName: string, stateName: string) => {
      return [
        {
          type: 'hospital',
          name: `Hospital Regional de ${cityName}`,
          description: 'Atendimento médico de emergência e especialidades',
          externalUrl: `https://www.saude.${stateName.toLowerCase()}.gov.br/hospitais`
        },
        {
          type: 'school',
          name: `Escola Estadual de ${cityName}`,
          description: 'Ensino fundamental e médio com qualidade reconhecida',
          externalUrl: `https://www.educacao.${stateName.toLowerCase()}.gov.br/escolas`
        },
        {
          type: 'landmark',
          name: `Prefeitura Municipal de ${cityName}`,
          description: 'Centro administrativo e serviços públicos',
          externalUrl: `https://www.${cityName.toLowerCase().replace(/ /g, '')}.${stateName.toLowerCase()}.gov.br`
        },
        {
          type: 'landmark',
          name: `Fórum de ${cityName}`,
          description: 'Centro de justiça e serviços jurídicos',
          externalUrl: `https://www.tj${stateName.toLowerCase()}.jus.br`
        }
      ];
    };

    // Force rebuild 2 - $(date)
    const touristAttractions = generateTouristAttractions(city.name, city.state.name);
    const publicUtilities = generatePublicUtilities(city.name, city.state.name);

    return (
      <>
        <CityStructuredData city={city} state={city.state} url={canonicalUrl} />
        <BreadcrumbStructuredData items={breadcrumbItems} />
        
        <div className="min-h-screen bg-gray-50">
          <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            {/* Breadcrumb */}
            <Breadcrumb className="mb-6">
              <BreadcrumbList>
                <BreadcrumbItem>
                  <BreadcrumbLink href="/">Home</BreadcrumbLink>
                </BreadcrumbItem>
                <BreadcrumbSeparator />
                <BreadcrumbItem>
                  <BreadcrumbLink href={`/estado/${city.state.slug}`}>
                    {city.state.name}
                  </BreadcrumbLink>
                </BreadcrumbItem>
                <BreadcrumbSeparator />
                <BreadcrumbItem>
                  <BreadcrumbPage>{city.name}</BreadcrumbPage>
                </BreadcrumbItem>
              </BreadcrumbList>
            </Breadcrumb>

            {/* City Header */}
            <div className="bg-white rounded-lg shadow-sm p-6 mb-8">
              <div className="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
                <div>
                  <h1 className="text-4xl font-bold text-gray-900 mb-2">
                    <strong>DDD de {city.name}</strong> - Guia Completo{city.isCapital ? ` da Capital do ${city.state.name}` : ` de ${city.state.name}`}
                  </h1>
                  <div className="flex items-center gap-4 text-gray-600 mb-2">
                    <div className="flex items-center gap-1">
                      <MapPin className="h-4 w-4" />
                      <span>{city.state.name}</span>
                    </div>
                    <Badge variant="secondary">{city.state.code}</Badge>
                    {city.isCapital && (
                      <Badge className="bg-yellow-100 text-yellow-800">Capital</Badge>
                    )}
                  </div>
                  <p className="text-lg text-gray-600">
                    {formatNumber(city.population)} habitantes • {city.dddCodes.length} códigos DDD • {formatArea(city.area)}
                  </p>
                </div>
                <div className="mt-4 md:mt-0">
                  <Link href={`/estado/${city.state.slug}`}>
                    <Button variant="outline" size="lg">
                      <ArrowLeft className="h-4 w-4 mr-2" />
                      Voltar para {city.state.name}
                    </Button>
                  </Link>
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div className="flex items-center gap-3">
                  <Users className="h-8 w-8 text-blue-600" />
                  <div>
                    <div className="text-2xl font-bold text-gray-900">
                      {formatNumber(city.population)}
                    </div>
                    <div className="text-sm text-gray-600">Habitantes</div>
                  </div>
                </div>
                <div className="flex items-center gap-3">
                  <Globe className="h-8 w-8 text-green-600" />
                  <div>
                    <div className="text-2xl font-bold text-gray-900">
                      {formatArea(city.area)}
                    </div>
                    <div className="text-sm text-gray-600">Área</div>
                  </div>
                </div>
                <div className="flex items-center gap-3">
                  <Phone className="h-8 w-8 text-red-600" />
                  <div>
                    <div className="text-2xl font-bold text-gray-900">
                      {city.dddCodes.length}
                    </div>
                    <div className="text-sm text-gray-600">Códigos DDD</div>
                  </div>
                </div>
                <div className="flex items-center gap-3">
                  <Building className="h-8 w-8 text-purple-600" />
                  <div>
                    <div className="text-2xl font-bold text-gray-900">
                      {city.isCapital ? 'Sim' : 'Não'}
                    </div>
                    <div className="text-sm text-gray-600">Capital</div>
                  </div>
                </div>
              </div>
            </div>

            {/* Main Content with Tabs */}
            <Tabs defaultValue="informacoes" className="space-y-8">
              <TabsList className="grid w-full grid-cols-4 lg:w-auto lg:inline-flex">
                <TabsTrigger value="informacoes" className="text-sm">
                  Informações
                </TabsTrigger>
                <TabsTrigger value="turismo" className="text-sm">
                  Turismo
                </TabsTrigger>
                <TabsTrigger value="historia" className="text-sm">
                  História
                </TabsTrigger>
                <TabsTrigger value="curiosidades" className="text-sm">
                  Curiosidades
                </TabsTrigger>
              </TabsList>

              {/* Information Tab */}
              <TabsContent value="informacoes" className="space-y-6">
                <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
                  <div className="lg:col-span-2 space-y-6">
                    {/* City Map */}
                    <Card>
                      <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                          <MapPin className="h-5 w-5" />
                          Localização Geográfica
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <CityMap 
                          cityName={city.name}
                          stateName={city.state.name}
                          latitude={city.latitude || -9.974}
                          longitude={city.longitude || -67.8243}
                        />
                      </CardContent>
                    </Card>

                    {/* DDD Information */}
                    <Card>
                      <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                          <Phone className="h-5 w-5" />
                          Códigos DDD de {city.name}
                        </CardTitle>
                        <CardDescription>
                          Informações sobre os códigos de área telefônica da cidade
                        </CardDescription>
                      </CardHeader>
                      <CardContent className="space-y-4">
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                          {city.dddCodes.map((ddd) => (
                            <div key={ddd.id} className="p-4 bg-blue-50 rounded-lg">
                              <div className="flex items-center justify-between mb-2">
                                <h4 className="text-lg font-semibold text-blue-900">
                                  DDD <strong>{ddd.code}</strong>
                                </h4>
                                <Badge className="bg-blue-100 text-blue-800">
                                  Ativo
                                </Badge>
                              </div>
                              <p className="text-sm text-blue-700">
                                {ddd.description || `Código DDD para ${city.name} e região`}
                              </p>
                              <div className="mt-3 text-xs text-blue-600">
                                <strong>Como ligar:</strong> 0 + {ddd.code} + número do telefone
                              </div>
                            </div>
                          ))}
                        </div>
                        <div className="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                          <h5 className="font-semibold text-yellow-800 mb-2">Importante</h5>
                          <p className="text-sm text-yellow-700">
                            O código DDD <strong>{city.dddCodes[0]?.code}</strong> é essencial para fazer 
                            ligações para <strong>{city.name}</strong>. Sem ele, sua chamada não será 
                            completada corretamente. Lembre-se de incluir o código da operadora para 
                            ligações interurbanas.
                          </p>
                        </div>
                      </CardContent>
                    </Card>

                    {/* Essential Services */}
                    <Card>
                      <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                          <Building className="h-5 w-5" />
                          Serviços Essenciais
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                          <div className="space-y-4">
                            <h4 className="font-semibold text-gray-900 flex items-center gap-2">
                              <Hospital className="h-4 w-4 text-red-600" />
                              Saúde
                            </h4>
                            <ul className="space-y-2 text-sm text-gray-600">
                              <li>• <a href="#" target="_blank" rel="noopener noreferrer" className="text-blue-600 hover:underline">Hospital Municipal</a></li>
                              <li>• <a href="#" target="_blank" rel="noopener noreferrer" className="text-blue-600 hover:underline">UPA 24h</a></li>
                              <li>• <a href="#" target="_blank" rel="noopener noreferrer" className="text-blue-600 hover:underline">Postos de Saúde</a></li>
                              <li>• <a href="tel:192" className="text-blue-600 hover:underline">SAMU - 192</a></li>
                            </ul>
                          </div>
                          <div className="space-y-4">
                            <h4 className="font-semibold text-gray-900 flex items-center gap-2">
                              <GraduationCap className="h-4 w-4 text-blue-600" />
                              Educação
                            </h4>
                            <ul className="space-y-2 text-sm text-gray-600">
                              <li>• <a href="#" target="_blank" rel="noopener noreferrer" className="text-blue-600 hover:underline">Escolas Municipais</a></li>
                              <li>• <a href="#" target="_blank" rel="noopener noreferrer" className="text-blue-600 hover:underline">Escolas Estaduais</a></li>
                              <li>• <a href="#" target="_blank" rel="noopener noreferrer" className="text-blue-600 hover:underline">Biblioteca Pública</a></li>
                              <li>• <a href="#" target="_blank" rel="noopener noreferrer" className="text-blue-600 hover:underline">Universidades</a></li>
                            </ul>
                          </div>
                        </div>
                      </CardContent>
                    </Card>

                    {/* How to Call */}
                    <Card>
                      <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                          <Phone className="h-5 w-5" />
                          Como Fazer Ligações para {city.name}
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                          <div className="space-y-4">
                            <h4 className="font-semibold text-gray-900">Do Brasil</h4>
                            <div className="p-4 bg-gray-50 rounded-lg">
                              <p className="font-mono text-sm mb-2">
                                0 + {city.dddCodes[0]?.code} + número do telefone
                              </p>
                              <p className="text-xs text-gray-600">
                                Inclua o código da operadora para ligações interurbanas
                              </p>
                            </div>
                          </div>
                          <div className="space-y-4">
                            <h4 className="font-semibold text-gray-900">Do Exterior</h4>
                            <div className="p-4 bg-gray-50 rounded-lg">
                              <p className="font-mono text-sm mb-2">
                                +55 + {city.dddCodes[0]?.code} + número do telefone
                              </p>
                              <p className="text-xs text-gray-600">
                                Não esqueça de remover o zero do DDD
                              </p>
                            </div>
                          </div>
                        </div>
                      </CardContent>
                    </Card>
                  </div>

                  {/* Sidebar */}
                  <div className="space-y-6">
                    {/* Quick Facts */}
                    <Card>
                      <CardHeader>
                        <CardTitle className="text-lg">Fatos Rápidos</CardTitle>
                      </CardHeader>
                      <CardContent className="space-y-3">
                        <div className="p-3 bg-blue-50 rounded-lg">
                          <h5 className="font-semibold text-blue-900">População</h5>
                          <p className="text-sm text-blue-700">{formatNumber(city.population)} habitantes</p>
                        </div>
                        <div className="p-3 bg-green-50 rounded-lg">
                          <h5 className="font-semibold text-green-900">Extensão</h5>
                          <p className="text-sm text-green-700">{formatArea(city.area)}</p>
                        </div>
                        <div className="p-3 bg-yellow-50 rounded-lg">
                          <h5 className="font-semibold text-yellow-900">Clima</h5>
                          <p className="text-sm text-yellow-700">Clima regional típico</p>
                        </div>
                        <div className="p-3 bg-purple-50 rounded-lg">
                          <h5 className="font-semibold text-purple-900">Economia</h5>
                          <p className="text-sm text-purple-700">Atividades locais</p>
                        </div>
                      </CardContent>
                    </Card>

                    {/* Author Card */}
                    <AuthorCard />

                    {/* Related Links */}
                    <RelatedLinks 
                      currentState={city.state.name}
                      currentRegion={city.state.region}
                      limit={6}
                    />
                  </div>
                </div>
              </TabsContent>

              {/* Tourism Tab */}
              <TabsContent value="turismo" className="space-y-6">
                <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
                  <div className="lg:col-span-2 space-y-6">
                    <Card>
                      <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                          <Camera className="h-5 w-5" />
                          Pontos Turísticos de {city.name}
                        </CardTitle>
                        <CardDescription>
                          Conheça os principais atrativos turísticos da cidade
                        </CardDescription>
                      </CardHeader>
                      <CardContent>
                        <div className="space-y-4">
                          {touristAttractions.map((attraction, index) => (
                            <div key={index} className="p-4 border rounded-lg">
                              <h4 className="font-semibold text-gray-900 mb-2">{attraction.name}</h4>
                              <p className="text-sm text-gray-600">{attraction.description}</p>
                              <div className="mt-2 flex items-center gap-2 text-xs text-gray-500">
                                <MapPin className="h-3 w-3" />
                                <span>{attraction.location}</span>
                              </div>
                            </div>
                          ))}
                        </div>
                      </CardContent>
                    </Card>

                    <Card>
                      <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                          <TreePine className="h-5 w-5" />
                          Cultura e Tradições
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <p className="text-gray-600">
                          {city.name} possui uma rica cultura local, com tradições que refletem 
                          a diversidade do {city.state.name}. A cidade celebra diversas festividades 
                          ao longo do ano, atraindo visitantes de toda a região.
                        </p>
                      </CardContent>
                    </Card>
                  </div>

                  <div className="space-y-6">
                    <Card>
                      <CardHeader>
                        <CardTitle className="text-lg">Melhor Época para Visitar</CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="space-y-3">
                          <div className="p-3 bg-green-50 rounded-lg">
                            <h5 className="font-semibold text-green-900">Estação Seca</h5>
                            <p className="text-sm text-green-700">Ideal para atividades ao ar livre</p>
                          </div>
                          <div className="p-3 bg-blue-50 rounded-lg">
                            <h5 className="font-semibold text-blue-900">Festivais Locais</h5>
                            <p className="text-sm text-blue-700">Confira o calendário de eventos</p>
                          </div>
                        </div>
                      </CardContent>
                    </Card>

                    <AuthorCard />
                  </div>
                </div>
              </TabsContent>

              {/* History Tab */}
              <TabsContent value="historia" className="space-y-6">
                <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
                  <div className="lg:col-span-2 space-y-6">
                    <Card>
                      <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                          <Clock className="h-5 w-5" />
                          História de {city.name}
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="space-y-4">
                          <div>
                            <h4 className="font-semibold text-gray-900 mb-2">Fundação</h4>
                            <p className="text-gray-600">
                              {city.name} foi fundada{city.isCapital ? ' como capital do estado' : ''} 
                              e desempenha um papel importante no desenvolvimento do {city.state.name}. 
                              A cidade cresceu e se desenvolveu ao longo dos anos, tornando-se um 
                              centro regional importante.
                            </p>
                          </div>
                          
                          <div>
                            <h4 className="font-semibold text-gray-900 mb-2">Desenvolvimento</h4>
                            <p className="text-gray-600">
                              Ao longo de sua história, {city.name} passou por diversas transformações 
                              econômicas e sociais. A infraestrutura de telecomunicações, incluindo 
                              o código DDD {city.dddCodes[0]?.code}, foi fundamental para o 
                              desenvolvimento da região.
                            </p>
                          </div>

                          <div>
                            <h4 className="font-semibold text-gray-900 mb-2">Era Moderna</h4>
                            <p className="text-gray-600">
                              Hoje, {city.name} se destaca como um importante centro urbano no 
                              {city.state.name}, com aproximadamente {formatNumber(city.population)} 
                              habitantes e uma economia diversificada.
                            </p>
                          </div>
                        </div>
                      </CardContent>
                    </Card>

                    <Card>
                      <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                          <Landmark className="h-5 w-5" />
                          Marcos Históricos
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                          <div className="p-4 border rounded-lg">
                            <h5 className="font-semibold text-gray-900 mb-2">Centro Histórico</h5>
                            <p className="text-sm text-gray-600">
                              Preserva a arquitetura e a história dos primeiros anos da cidade
                            </p>
                          </div>
                          <div className="p-4 border rounded-lg">
                            <h5 className="font-semibold text-gray-900 mb-2">Praça Principal</h5>
                            <p className="text-sm text-gray-600">
                              Coração da cidade, onde acontecem os principais eventos culturais
                            </p>
                          </div>
                        </div>
                      </CardContent>
                    </Card>
                  </div>

                  <div className="space-y-6">
                    <Card>
                      <CardHeader>
                        <CardTitle className="text-lg">Linha do Tempo</CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="space-y-3">
                          <div className="p-3 border-l-4 border-blue-500">
                            <h5 className="font-semibold text-sm">Fundação</h5>
                            <p className="text-xs text-gray-600">Início do povoamento</p>
                          </div>
                          <div className="p-3 border-l-4 border-green-500">
                            <h5 className="font-semibold text-sm">Desenvolvimento</h5>
                            <p className="text-xs text-gray-600">Crescimento econômico</p>
                          </div>
                          <div className="p-3 border-l-4 border-purple-500">
                            <h5 className="font-semibold text-sm">Modernização</h5>
                            <p className="text-xs text-gray-600">Infraestrutura urbana</p>
                          </div>
                        </div>
                      </CardContent>
                    </Card>

                    <AuthorCard />
                  </div>
                </div>
              </TabsContent>

              {/* Curiosities Tab */}
              <TabsContent value="curiosidades" className="space-y-6">
                <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
                  <div className="lg:col-span-2 space-y-6">
                    <Card>
                      <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                          <Star className="h-5 w-5" />
                          Curiosidades sobre {city.name}
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="space-y-4">
                          <div className="p-4 bg-yellow-50 rounded-lg">
                            <h4 className="font-semibold text-yellow-900 mb-2">Você sabia?</h4>
                            <p className="text-sm text-yellow-700">
                              {city.name} possui o código DDD {city.dddCodes[0]?.code}, 
                              que é compartilhado com outras cidades importantes da região.
                            </p>
                          </div>
                          
                          <div className="p-4 bg-blue-50 rounded-lg">
                            <h4 className="font-semibold text-blue-900 mb-2">População</h4>
                            <p className="text-sm text-blue-700">
                              Com aproximadamente {formatNumber(city.population)} habitantes, 
                              {city.name} é uma das cidades mais populosas do {city.state.name}.
                            </p>
                          </div>

                          <div className="p-4 bg-green-50 rounded-lg">
                            <h4 className="font-semibold text-green-900 mb-2">Geografia</h4>
                            <p className="text-sm text-green-700">
                              A cidade ocupa uma área de {formatArea(city.area)}, 
                              oferecendo diversidade de paisagens e ambientes naturais.
                            </p>
                          </div>

                          <div className="p-4 bg-purple-50 rounded-lg">
                            <h4 className="font-semibold text-purple-900 mb-2">Importância Regional</h4>
                            <p className="text-sm text-purple-700">
                              {city.name} desempenha um papel fundamental na economia e 
                              na infraestrutura de telecomunicações da região.
                            </p>
                          </div>
                        </div>
                      </CardContent>
                    </Card>

                    <Card>
                      <CardHeader>
                        <CardTitle className="flex items-center gap-2">
                          <Phone className="h-5 w-5" />
                          Dados sobre o Código DDD
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="space-y-3">
                          <div>
                            <h4 className="font-semibold text-gray-900 mb-1">Código DDD</h4>
                            <p className="text-sm text-gray-600">
                              O código {city.dddCodes[0]?.code} identifica {city.name} no sistema 
                              de telefonia brasileiro e é essencial para todas as ligações.
                            </p>
                          </div>
                          <div>
                            <h4 className="font-semibold text-gray-900 mb-1">Cobertura</h4>
                            <p className="text-sm text-gray-600">
                              Este código DDD atende não apenas {city.name}, mas também outras 
                              localidades próximas da região.
                            </p>
                          </div>
                          <div>
                            <h4 className="font-semibold text-gray-900 mb-1">Operadoras</h4>
                            <p className="text-sm text-gray-600">
                              Todas as principais operadoras de telefonia móvel e fixa operam 
                              com o código DDD {city.dddCodes[0]?.code} na região.
                            </p>
                          </div>
                        </div>
                      </CardContent>
                    </Card>
                  </div>

                  <div className="space-y-6">
                    <Card>
                      <CardHeader>
                        <CardTitle className="text-lg">Dados Rápidos</CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="space-y-3">
                          <div className="flex justify-between">
                            <span className="text-sm text-gray-600">Código IBGE:</span>
                            <span className="text-sm font-medium">-</span>
                          </div>
                          <div className="flex justify-between">
                            <span className="text-sm text-gray-600">PIB per capita:</span>
                            <span className="text-sm font-medium">-</span>
                          </div>
                          <div className="flex justify-between">
                            <span className="text-sm text-gray-600">IDH:</span>
                            <span className="text-sm font-medium">-</span>
                          </div>
                          <div className="flex justify-between">
                            <span className="text-sm text-gray-600">Código DDD:</span>
                            <span className="text-sm font-medium">{city.dddCodes[0]?.code}</span>
                          </div>
                        </div>
                      </CardContent>
                    </Card>

                    <AuthorCard />
                  </div>
                </div>
              </TabsContent>
            </Tabs>

            {/* Nearby Cities Section */}
            {nearbyCities.length > 0 && (
              <section className="mt-8">
                <h2 className="text-2xl font-bold text-gray-900 mb-6">
                  Outras Cidades do {city.state.name}
                </h2>
                
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                  {nearbyCities.map((nearbyCity) => (
                    <Card key={nearbyCity.id} className="hover:shadow-md transition-shadow">
                      <CardHeader className="pb-3">
                        <CardTitle className="text-lg">
                          <Link 
                            href={`/estado/${nearbyCity.state.slug}/${nearbyCity.slug}`}
                            className="hover:text-blue-600 transition-colors"
                          >
                            {nearbyCity.name}
                          </Link>
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="space-y-2">
                          <div className="flex items-center gap-2 text-sm">
                            <Users className="h-3 w-3" />
                            <span>{formatNumber(nearbyCity.population)} habitantes</span>
                          </div>
                          <div className="flex items-center gap-2 text-sm">
                            <Phone className="h-3 w-3" />
                            <span>DDD {nearbyCity.dddCodes[0]?.code}</span>
                          </div>
                        </div>
                      </CardContent>
                    </Card>
                  ))}
                </div>
              </section>
            )}

            {/* FAQ Section */}
            <section className="mt-8">
              <h2 className="text-2xl font-bold text-gray-900 mb-6">
                Perguntas Frequentes sobre o DDD de {city.name}
              </h2>
              
              <Accordion type="single" collapsible className="w-full">
                <AccordionItem value="item-1">
                  <AccordionTrigger>Qual é o código DDD de {city.name}?</AccordionTrigger>
                  <AccordionContent>
                    <p className="text-gray-600">
                      O código DDD de {city.name} é {city.dddCodes[0]?.code}. Este código atende a toda a região de {city.name} e deve ser utilizado para fazer ligações telefônicas para esta cidade.
                    </p>
                  </AccordionContent>
                </AccordionItem>
                
                <AccordionItem value="item-2">
                  <AccordionTrigger>Como fazer ligações para {city.name}?</AccordionTrigger>
                  <AccordionContent>
                    <p className="text-gray-600 mb-2">
                      Para fazer ligações para {city.name}, siga o formato correto:
                    </p>
                    <ul className="list-disc list-inside text-gray-600 space-y-1">
                      <li>De dentro do Brasil: 0 + {city.dddCodes[0]?.code} + número do telefone</li>
                      <li>Do exterior: +55 + {city.dddCodes[0]?.code} + número do telefone</li>
                      <li>Para celulares: adicione o 9 após o DDD</li>
                    </ul>
                  </AccordionContent>
                </AccordionItem>
                
                <AccordionItem value="item-3">
                  <AccordionTrigger>{city.name} é capital do estado?</AccordionTrigger>
                  <AccordionContent>
                    <p className="text-gray-600">
                      {city.isCapital 
                        ? `Sim, ${city.name} é a capital do estado do ${city.state.name}. É o principal centro político, econômico e administrativo da região.`
                        : `Não, ${city.name} não é a capital do ${city.state.name}. A capital é ${city.state.capital}.`
                      }
                    </p>
                  </AccordionContent>
                </AccordionItem>
                
                <AccordionItem value="item-4">
                  <AccordionTrigger>Quantos habitantes tem {city.name}?</AccordionTrigger>
                  <AccordionContent>
                    <p className="text-gray-600">
                      De acordo com os dados mais recentes, {city.name} tem aproximadamente {formatNumber(city.population)} habitantes, sendo uma das cidades mais importantes do {city.state.name}.
                    </p>
                  </AccordionContent>
                </AccordionItem>
              </Accordion>
            </section>
          </div>
        </div>
      </>
    );

  } catch (error) {
    console.error('Error in CityPage:', error);
    notFound();
  }
}
