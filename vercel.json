{
  "buildCommand": "npm run build:vercel",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://meuddd.com/:1",
      "has": [
        {
          "type": "host",
          "value": "www.meuddd.com"
        }
      ]
    }
  ]
}