+        ],
+        max_tokens: 600,
+        temperature: 0.6
+      })
+
+      const content = completion.choices[0]?.message?.content || ''
+      
+      // Parse the response into an array
+      const lines = content.split('\n').filter(line => line.trim())
+      return lines.slice(0, 10) // Limit to 10 items
