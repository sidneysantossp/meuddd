+          </div>
+        </CardContent>
+      </Card>
+
+      {/* Curiosidades */}
+      <Card>
+        <CardHeader>
+          <CardTitle>Informações Relevantes</CardTitle>
+        </CardHeader>
+        <CardContent className="space-y-4">
